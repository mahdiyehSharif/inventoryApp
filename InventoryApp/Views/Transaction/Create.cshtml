@model InventoryApp.ServiceContracts.DTO.TransactionAddRequest

@{
    ViewData["Title"] = "Create Transaction";
}

<div class="container">

    <div class="card shadow">

        <div class="card-header">
            <h3>Create Transaction</h3>
        </div>

        <div class="card-body">

            <form asp-controller="Transaction"
                  asp-action="Create"
                  method="post">

                <div asp-validation-summary="All"
                     class="text-danger mb-3">
                </div>

                <!-- Product -->

                <div class="mb-3">

                    <label asp-for="ProductID"
                           class="form-label">
                        Product
                    </label>

                    <select asp-for="ProductID"
                            class="form-select">

                        <option value="">
                            Select Product
                        </option>

                        @if(ViewBag.Products != null)
                        {
                            foreach(var product in ViewBag.Products)
                            {
                                <option value="@product.ProductID">
                                    @product.ProductName
                                </option>
                            }
                        }

                    </select>

                </div>

                <!-- Employee -->

                <div class="mb-3">

                    <label asp-for="EmployeeID"
                           class="form-label">
                        Employee
                    </label>

                    <select asp-for="EmployeeID"
                            class="form-select">

                        <option value="">
                            Select Employee
                        </option>

                        @if(ViewBag.Employees != null)
                        {
                            foreach(var employee in ViewBag.Employees)
                            {
                                <option value="@employee.EmployeeID">
                                    @employee.EmployeeName
                                </option>
                            }
                        }

                    </select>

                </div>

                <!-- Transaction Type -->

                <div class="mb-3">

                    <label asp-for="Type"
                           class="form-label">
                        Transaction Type
                    </label>

                    <select asp-for="Type"
                            class="form-select">

                        <option value="">
                            Select Type
                        </option>

                        <option value="In">
                            Stock In
                        </option>

                        <option value="Out">
                            Stock Out
                        </option>

                    </select>

                </div>

                <!-- Amount -->

                <div class="mb-3">

                    <label asp-for="Amount"
                           class="form-label">
                        Amount
                    </label>

                    <input asp-for="Amount"
                           class="form-control" />

                    <span asp-validation-for="Amount"
                          class="text-danger">
                    </span>

                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-success">
                        Save Transaction
                    </button>

                    <a asp-controller="Transaction"
                       asp-action="Index"
                       class="btn btn-secondary">
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}