@model ServiceContracts.DTO.EmployeeUpdateRequest

@{
    ViewData["Title"] = "Edit Employee";
}

<hr />

<form asp-action="Edit" method="post">

    @Html.AntiForgeryToken()

    <input asp-for="EmployeeID" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">

        <label asp-for="FName" class="form-label"></label>

        <input asp-for="FName" class="form-control" />

        <span asp-validation-for="FName" class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label asp-for="LName" class="form-label"></label>

        <input asp-for="LName" class="form-control" />

        <span asp-validation-for="LName" class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label asp-for="JobID" class="form-label"></label>

        <select asp-for="JobID" asp-items="ViewBag.Jobs" class="form-select">

            <option value="">-- Select Job --</option>

        </select>

        <span asp-validation-for="JobID" class="text-danger"></span>

    </div>

    <button type="submit" class="btn btn-primary">

        Update

    </button>

    <a asp-action="Index" class="btn btn-secondary">

        Cancel

    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}