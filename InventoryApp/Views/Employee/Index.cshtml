@model List<InventoryApp.ServiceContracts.DTO.EmployeeResponse>
@using InventoryApp.ServiceContracts.DTO    

@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between mb-3">

    <a asp-action="Create" class="btn btn-primary">
        + Add Employee
    </a>
</div>

<table class="table table-bordered table-hover">

    <thead>
        <tr>
            <th>ID</th>
            <th>Full Name</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Job</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (EmployeeResponse emp in Model)
        {
            <tr>
                <td>@emp.EmployeeID</td>
                <td>@emp.FullName</td>
                <td>@emp.FName</td>
                <td>@emp.LName</td>
                <td>@emp.JobName</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@emp.EmployeeID"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <form asp-action="Delete"
                          asp-route-id="@emp.EmployeeID"
                          method="post"
                          class="d-inline">

                        <button class="btn btn-sm btn-danger"
                                onclick="return confirm('Are you sure?')">
                            Delete
                        </button>

                    </form>
                </td>
            </tr>
        }
    </tbody>

</table>